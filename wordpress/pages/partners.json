        "postContent": "<!-- wp:generateblocks/container {\"uniqueId\":\"d6eb410d\",\"isDynamic\":true,\"blockVersion\":4} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"bca044f6\",\"isDynamic\":true,\"blockVersion\":4,\"useGlobalMaxWidth\":true,\"spacing\":{\"marginRight\":\"auto\",\"marginLeft\":\"auto\"}} -->\n<!-- wp:generateblocks/grid {\"uniqueId\":\"532f4855\",\"columns\":14,\"horizontalGap\":40,\"verticalGap\":40,\"isDynamic\":true,\"blockVersion\":3} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"dc7cd784\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:generateblocks/image {\"uniqueId\":\"34b0e04c\",\"mediaId\":4566,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2,\"spacing\":{\"marginBottom\":\"20px\"}} -->\n<figure class=\"gb-block-image gb-block-image-34b0e04c\"><img class=\"gb-image gb-image-34b0e04c\" src=\"{{pushpull.home_url}}/app/uploads/logos_Ecolint_blue.png\" alt=\"\" title=\"logos_Ecolint_blue\"/></figure>\n<!-- /wp:generateblocks/image -->\n\n<!-- wp:generateblocks/image {\"uniqueId\":\"04307ab5\",\"mediaId\":4567,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2,\"spacing\":{\"marginBottom\":\"20px\"}} -->\n<figure class=\"gb-block-image gb-block-image-04307ab5\"><img class=\"gb-image gb-image-04307ab5\" src=\"{{pushpull.home_url}}/app/uploads/Ecolint_Campus-de-La-Chataigneraie_small.jpg\" alt=\"\" title=\"Ecolint_Campus de La Châtaigneraie_small\"/></figure>\n<!-- /wp:generateblocks/image -->\n\n<!-- wp:generateblocks/image {\"uniqueId\":\"9f5a5273\",\"mediaId\":4568,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2,\"spacing\":{\"marginBottom\":\"20px\"}} -->\n<figure class=\"gb-block-image gb-block-image-9f5a5273\"><img class=\"gb-image gb-image-9f5a5273\" src=\"{{pushpull.home_url}}/app/uploads/Ecolint_Campus-de-La-Grande-Boissiere_small.jpg\" alt=\"\" title=\"Ecolint_Campus de La Grande Boissière_small\"/></figure>\n<!-- /wp:generateblocks/image -->\n\n<!-- wp:generateblocks/image {\"uniqueId\":\"d073f5d5\",\"mediaId\":4569,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2} -->\n<figure class=\"gb-block-image gb-block-image-d073f5d5\"><img class=\"gb-image gb-image-d073f5d5\" src=\"{{pushpull.home_url}}/app/uploads/Ecolint_Campus-des-Nations_small.jpg\" alt=\"\" title=\"Ecolint_Campus des Nations_small\"/></figure>\n<!-- /wp:generateblocks/image --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"width\":\"66.66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:generateblocks/headline {\"uniqueId\":\"11228078\",\"element\":\"p\",\"blockVersion\":3,\"spacing\":{\"marginBottom\":\"0px\"}} -->\n<p class=\"gb-headline gb-headline-11228078 gb-headline-text\">[go_link src=\"partners\" url=\"https://www.ecolint.ch/fr\"]L’Ecole Internationale de Genève (Ecolint)[/go_link] - Founded in 1924, the International School of Geneva, commonly known as Ecolint, is the oldest international school in the world. It is located in Geneva, Switzerland, and has three campuses: La Grande Boissière, La Châtaigneraie, and Campus des Nations.<br>Ecolint welcomes students of all nationalities, promoting peace, intercultural understanding, and global citizenship. It offers bilingual and international curricula, including the International Baccalaureate (IB) programmes. The school emphasises academic excellence, diversity, and values-driven education.<br>Mission: “To educate students to be global citizens with the courage and capacity to create a just and joyful tomorrow together.” Ecolint is committed to inclusive, equitable, and innovative education grounded in humanist values.</p>\n<!-- /wp:generateblocks/headline --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"4a0662bd\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:group {\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\"}} -->\n<div class=\"wp-block-group\"><!-- wp:generateblocks/image {\"uniqueId\":\"735aac09\",\"mediaId\":4011,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"large\",\"blockVersion\":2} -->\n<figure class=\"gb-block-image gb-block-image-735aac09\"><img class=\"gb-image gb-image-735aac09\" src=\"{{pushpull.home_url}}/app/uploads/NI-banner-horizontal-2.png\" alt=\"\" title=\"NI-banner-horizontal-2\"/></figure>\n<!-- /wp:generateblocks/image -->\n\n<!-- wp:generateblocks/headline {\"uniqueId\":\"a330b822\",\"element\":\"p\",\"blockVersion\":3,\"spacing\":{\"marginBottom\":\"0px\"}} -->\n<p class=\"gb-headline gb-headline-a330b822 gb-headline-text\">Before settling permanently in Portugal, we traveled around Europe to try out different countries and used [go_link src=\"partners\" url=\"https://safetywing.com/nomad-insurance/?referenceID=26270047&amp;campaign=leman-events-partner-page&amp;utm_campaign=leman-events-partner-page&amp;utm_source=26270047&amp;utm_medium=Ambassador\"]SafetyWing Nomad Insurance[/go_link] to make sure we had appropriate health coverage for our family of 3! Highly recommended :-) - MC &amp; J, Léman Events co-founders</p>\n<!-- /wp:generateblocks/headline --></div>\n<!-- /wp:group -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"f5149446\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:co