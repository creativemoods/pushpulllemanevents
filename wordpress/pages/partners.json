n --></div>\n<!-- /wp:columns -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"ce28366f\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:generateblocks/image {\"uniqueId\":\"e5706d34\",\"mediaId\":3651,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2} -->\n<figure class=\"gb-block-image gb-block-image-e5706d34\"><img class=\"gb-image gb-image-e5706d34\" src=\"{{pushpull.home_url}}/app/uploads/littlepandas.png\" alt=\"\" title=\"littlepandas\"/></figure>\n<!-- /wp:generateblocks/image --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"width\":\"66.66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:paragraph -->\n<p>[go_link src=\"partners\" url=\"https://littlepandas.ch/\"]Little Pandas[/go_link] is a Kids Club for children from birth to 10 years old, where every day is an adventure.<br>🎨 Creative workshops<br>🤸‍♂️ Gym &amp; Motor Skills<br>🎶 Music Discovery<br>🥕 Cooking Classes<br>🎂 Birthday Parties<br>🌼 Holiday Camps<br>🌿 Outdoor Activities &amp; much more!<br>A magical place where your children can explore, have fun, and learn in a safe environment.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"ae46ea78\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:generateblocks/image {\"uniqueId\":\"b8d3c095\",\"med