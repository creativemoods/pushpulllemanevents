\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-1d5ff44d gb-accordion__toggle\" id=\"gb-accordion-toggle-1d5ff44d\"><span class=\"gb-button-text\">I subscribed but didn't receive my access details.</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"c75d9daf\",\"anchor\":\"gb-accordion-content-c75d9daf\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">It is possible that you will not receive your access details straight away when you subscribe because we have a manual process to validate your registration. If you haven’t received the information within two hours, remember to check your spam box. Various problems may also arise during registration (error in the email address provided, etc.). Please don’t hesitate to contact us.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->"
