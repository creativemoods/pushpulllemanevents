rdionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"b75498d9\",\"anchor\":\"gb-accordion-toggle-b75498d9\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-b75498d9 gb-accordion__toggle\" id=\"gb-accordion-toggle-b75498d9\"><span class=\"gb-button-text\">My browser does not automatically translate the content of the platform. What can I do?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.