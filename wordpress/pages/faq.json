        "postContent": "<!-- wp:generateblocks/container {\"uniqueId\":\"5a6344a3\",\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.22,\"overlay\":false,\"position\":\"center center\",\"size\":\"cover\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"spacing\":{\"paddingTop\":\"\",\"paddingBottom\":\"\"}} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"e7f79de8\",\"backgroundColor\":\"#ffffff\",\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"zindex\":9,\"useGlobalMaxWidth\":true,\"spacing\":{\"marginRight\":\"auto\",\"marginLeft\":\"auto\",\"paddingTop\":\"50px\",\"paddingBottom\":\"50px\",\"paddingLeft\":\"30px\",\"paddingRight\":\"30px\",\"paddingLeftMobile\":\"\",\"marginLeftMobile\":\"15px\",\"marginRightMobile\":\"15px\"}} -->\n<!-- wp:generateblocks/headline {\"uniqueId\":\"49c0c512\",\"element\":\"h4\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontSizeMobile\":\"20px\"},\"spacing\":{\"paddingLeft\":\"160px\",\"paddingRight\":\"160px\",\"marginTop\":\"-30px\",\"paddingLeftMobile\":\"0px\",\"paddingRightMobile\":\"0px\"}} -->\n<h4 class=\"gb-headline gb-headline-49c0c512 gb-headline-text\">Have questions? Prior to reaching out, we recommend carefully reviewing our FAQ section. It's possible that the information you're seeking is already available there.</h4>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"8c0b2148\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"spacing\":{\"marginTop\":\"50px\"}} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"10633a86\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion\",\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"51ad051a\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"7831e183\",\"anchor\":\"gb-accordion-toggle-7831e183\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-7831e183 gb-accordion__toggle\" id=\"gb-accordion-toggle-7831e183\"><span class=\"gb-button-text\">How can I/my event/my camp/my business be featured on the platform?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"2a797221\",\"anchor\":\"gb-accordion-content-2a797221\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">By subscribing, your organization will be integrated into our partner network, and your activities, events, and camps will be automatically listed on our platform, visible to thousands of families in the Lake Geneva region.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"15dbe0ca\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"ef06d70b\",\"anchor\":\"gb-accordion-toggle-ef06d70b\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-ef06d70b gb-accordion__toggle\" id=\"gb-accordion-toggle-ef06d70b\"><span class=\"gb-button-text\">Can I suggest an event/camp and what's the process?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"aafea4d1\",\"anchor\":\"gb-accordion-content-aafea4d1\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">If you know of any event/camp we might have missed, don’t hesitate to send us a link to it, we’ll do our best to list it on the platform. Please refer to the page&nbsp;<a href=\"{{pushpull.home_url}}/share-an-event/\" title=\"Share an event\">Share an event</a>.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"0b81edc6\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"0d5184d9\",\"anchor\":\"gb-accordion-toggle-0d5184d9\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-0d5184d9 gb-accordion__toggle\" id=\"gb-accordion-toggle-0d5184d9\"><span class=\"gb-button-text\">Can my email address and my personal data be shared with third parties?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"95dbdeaa\",\"anchor\":\"gb-accordion-content-95dbdeaa\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">We do not sell, trade, or otherwise transfer your personal information to third parties. Our Privacy Policy outlines how Léman Events collects, uses, discloses, and protects personal information from users who access and interact with our platform. Please refer to the page <a href=\"{{pushpull.home_url}}/privacy-policy/\" title=\"Privacy policy\">Privacy policy</a>.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"db318b88\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"cff2c0de\",\"anchor\":\"gb-accordion-toggle-cff2c0de\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-cff2c0de gb-accordion__toggle\" id=\"gb-accordion-toggle-cff2c0de\"><span class=\"gb-button-text\">How can I unsubscribe?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"f551f343\",\"anchor\":\"gb-accordion-content-f551f343\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">Are you sure you want to leave us? We are sorry to see you go! You can cancel your monthly subscription at any time by going to your personal account (under the \"My Memberships\" section). Please let us know why you are unsubscribing or what we could improve.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"068c86a6\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"d5df3be6\",\"anchor\":\"gb-accordion-toggle-d5df3be6\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-d5df3be6 gb-accordion__toggle\" id=\"gb-accordion-toggle-d5df3be6\"><span class=\"gb-button-text\">In what language is the platform?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-2