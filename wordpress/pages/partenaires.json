-->\n<div class=\"wp-block-columns\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:generateblocks/image {\"uniqueId\":\"f8fa0668\",\"mediaId\":3630,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2} -->\n<figure class=\"gb-block-image gb-block-image-f8fa0668\"><img class=\"gb-image gb-image-f8fa0668\" src=\"{{pushpull.home_url}}/app/uploads/Tilouco-picture-for-partners.png\" alt=\"\" title=\"Tilouco-picture for partners\"/></figure>\n<!-- /wp:generateblocks/image --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"width\":\"66.66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:generateblocks/headline {\"uniqueId\":\"5c763289\",\"element\":\"p\",\"blockVersion\":3,\"spacing\":{\"marginBottom\":\"0px\"}} -->\n<p class=\"gb-headline gb-headline-5c763289 gb-headline-text\"><strong>LA MARQUE SUISSE FUNKY ET MALINE POUR VOS MINIS</strong></p>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:paragraph -->\n<p>[go_link src=\"partners\" url=\"https://tilouco.com/\"]Tilouco[/go_link], c’est la marque créée dans le but d’apporter du confort aux bébés et de simplifier la vie des parents grâce à des tenues et accessoires confortables et bien pensés, en coton bio, avec des motifs exclusifs, colorés et unisexes.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:generateblocks/button {\"uniqueId\":\"2b2953b7\",\"hasUrl\":false,\"target\":true,\"relNoFollow\":true,\"relSponsored\":true,\"blockVersion\":4,\"display\":\"inline-flex\",\"alignItems\":\"center\",\"columnGap\":\"0.5em\",\"typography\":{\"fontSize\":\"14px\"},\"spacing\":{\"paddingTop\":\"8px\",\"paddingRight\":\"14px\",\"paddingBottom\":\"8px\",\"paddingLeft\":\"14px\",\"marginTop\":\"\"},\"backgroundColor\":\"#fb6542\",\"backgroundColorHover\":\"#375e97\",\"textColor\":\"#ffffff\",\"textColorHover\":\"#ffffff\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"i