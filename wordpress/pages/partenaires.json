66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:generateblocks/headline {\"uniqueId\":\"527b88e2\",\"element\":\"p\",\"blockVersion\":3} -->\n<p class=\"gb-headline gb-headline-527b88e2 gb-headline-text\">[go_link src=\"partners\" url=\"https://wonderbly.pxf.io/c/6098515/2101571/23212\"]Wonderbly[/go_link] crée des livres personnalisés pour les enfants et les adultes, enchantant plus de 10 millions de lecteurs depuis 2013. Il vous suffit d’ajouter un nom, de choisir un personnage et d’écrire une dédicace spéciale. Wonderbly le transforme en un livre unique mettant en scène vos proches (Maman, Papa, Papi, Mamie, votre nouveau-né, etc.), imprimé sur du papier de haute qualité et livré directement chez vous. Ce sont des cadeaux parfaits pour chaque moment important de votre vie !</p>\n<!-- /wp:generateblocks/headline --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"457b49c5\",\"isGrid\":true,\"gridId\":\"532f4855\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"width\":\"50%\",\"widthMobile\":\"100%\"}} -->\n<!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:generateblocks/image {\"uniqueId\":\"437a16cb\",\"mediaId\":4101,\"openInNewWindow\":true,\"relNoFollow\":true,\"relSponsored\":true,\"sizeSlug\":\"full\",\"blockVersion\":2} -->\n<figure class=\"gb-block-image gb-block-image-437a16cb\"><img class=\"gb-image gb-image-437a16cb\" src=\"{{pushpull.home_url}}/app/uploads/mapiful.webp\" alt=\"\" title=\"mapiful\"/></figure>\n<!-- /wp:generateblocks/image --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"width\":\"66.66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:generateblocks/headline {\"uniqueId\":\"82416df5\",\"element\":\"p\",\"blockVersion\":3,\"spacing\":{\"marginBottom\":\"0px\"}} -->\